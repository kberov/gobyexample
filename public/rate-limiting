    <script>
      var codeLines = [];
      codeLines.push('');codeLines.push('package main\u000A');codeLines.push('import (\u000A    \"fmt\"\u000A    \"time\"\u000A)\u000A');codeLines.push('func main() {\u000A');codeLines.push('    заявки :\u003D make(chan int, 5)\u000A    for i :\u003D 1; i \u003C\u003D 5; i++ {\u000A        заявки \u003C- i\u000A    }\u000A    close(заявки)\u000A');codeLines.push('    ограничител :\u003D time.Tick(200 * time.Millisecond)\u000A');codeLines.push('    for req :\u003D range заявки {\u000A        време :\u003D \u003C-ограничител\u000A        fmt.Println(\"заявка\",\u000A            req, време.Format(`15:04.000`))\u000A    }\u000A');codeLines.push('    разрешаващСкок :\u003D make(chan time.Time, 3)\u000A');codeLines.push('    for range 3 {\u000A        разрешаващСкок \u003C- time.Now()\u000A    }\u000A');codeLines.push('    go func() {\u000A        for t :\u003D range time.Tick(200 * time.Millisecond) {\u000A            разрешаващСкок \u003C- t\u000A        }\u000A    }()\u000A');codeLines.push('    скочилиЗаявки :\u003D make(chan int, 5)\u000A    for i :\u003D 1; i \u003C\u003D 5; i++ {\u000A        скочилиЗаявки \u003C- i\u000A    }\u000A    close(скочилиЗаявки)\u000A    for req :\u003D range скочилиЗаявки {\u000A        t :\u003D \u003C-разрешаващСкок\u000A        fmt.Println(\"заявки\",\u000A            req, t.Format(`15:04.000`))\u000A    }\u000A}\u000A');codeLines.push('');codeLines.push('');
    </script>
