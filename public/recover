    <script>
      var codeLines = [];
      codeLines.push('');codeLines.push('');codeLines.push('package main\u000A');codeLines.push('import \"fmt\"\u000A');codeLines.push('func можеДаУжаси() {\u000A    panic(struct{ a int }{a: 2})\u000A}\u000A');codeLines.push('func main() {\u000A');codeLines.push('    defer func() {\u000A        if r :\u003D recover(); r !\u003D nil {\u000A');codeLines.push('            fmt.Printf(\"Възстановено. Грешка: [%v]\\n\", r)\u000A        }\u000A    }()\u000A');codeLines.push('    можеДаУжаси()\u000A');codeLines.push('    fmt.Println(\"След можеДаУжаси()\")\u000A}\u000A');codeLines.push('');
