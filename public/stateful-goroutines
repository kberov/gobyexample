lisecond)\u000A            }\u000A        }()\u000A    }\u000A');codeLines.push('    time.Sleep(time.Second)\u000A');codeLines.push('    краенБройЧетения :\u003D atomic.LoadUint64(\u0026бройЧетения)\u000A    fmt.Println(\"Общо четения:\", краенБройЧетения)\u000A    краенБройПисания :\u003D atomic.LoadUint64(\u0026бройПисания)\u000A    fmt.Println(\"Общо писания:\", краенБройПисания)\u000A}\u000A');codeLines.push('');codeLines.push('');
