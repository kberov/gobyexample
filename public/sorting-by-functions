    </p>

    </div>
    <script>
      var codeLines = [];
      codeLines.push('');codeLines.push('package main\u000A');codeLines.push('import (\u000A    \"cmp\"\u000A    \"fmt\"\u000A    \"slices\"\u000A)\u000A');codeLines.push('func main() {\u000A    плодове :\u003D []string{\"праскова\", \"банан\", \"киви\"}\u000A');codeLines.push('    lenCmp :\u003D func(a, b string) int {\u000A        return cmp.Compare(len(a), len(b))\u000A    }\u000A');codeLines.push('    slices.SortFunc(плодове, lenCmp)\u000A    fmt.Println(плодове)\u000A');codeLines.push('    type Личност struct {\u000A        име     string\u000A        възраст int\u000A    }\u000A');codeLines.push('    народ :\u003D []Личност{\u000A        Личност{име: \"Пешо\", възраст: 37},\u000A        Личност{име: \"Иван\", възраст: 25},\u000A        Личност{име: \"Краси\", възраст: 72},\u000A    }\u000A');codeLines.push('    slices.SortFunc(народ,\u000A        func(a, b Личност) int {\u000A            return cmp.Compare(a.възраст, b.възраст)\u000A        })\u000A    fmt.Println(народ)\u000A}\u000A');codeLines.push('');
    </script>
    <script src="site.js" async></script>
