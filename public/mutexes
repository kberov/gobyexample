</span></span><span class="line"><span class="cl">        <span class="nx">увеличи</span><span class="p">(</span><span class="s">&#34;a&#34;</span><span class="p">,</span> <span class="mi">10000</span><span class="p">)</span>
</span></span><span class="line"><span class="cl">    <span class="p">})</span></span></span></code></pre>
